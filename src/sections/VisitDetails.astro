---
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import ReservationForm from '../components/ReservationForm';
import ContactForm from '../components/ContactForm';
import site from '../data/site.json';
---

<section class="bg-deep-charcoal py-20 sm:py-28">
  <Container>
    <div class="grid gap-12 lg:grid-cols-2">
      <!-- Map + Address -->
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-grill-orange">Location</p>
        <h2 class="mt-3 font-display text-3xl font-bold text-cream sm:text-4xl">Visit Ryndu</h2>

        <div class="mt-6 aspect-video overflow-hidden rounded-sm">
          <iframe
            src={site.googleMapsEmbed}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ryndu Hot & Grill location map"
            class="h-full w-full"
          ></iframe>
        </div>

        <div class="mt-8 space-y-5">
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-grill-orange/10 text-grill-orange">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-cream">Address</p>
              <p class="mt-0.5 text-sm text-cream/60">{site.address.full}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-grill-orange/10 text-grill-orange">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-cream">Hours</p>
              <p class="mt-0.5 text-sm text-cream/60">{site.hours.weekday.days}: {site.hours.weekday.label}</p>
              <p class="text-sm text-cream/60">{site.hours.weekend.days}: {site.hours.weekend.label}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-grill-orange/10 text-grill-orange">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-cream">Phone</p>
              <p class="mt-0.5 text-sm text-cream/60">{site.phone}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-grill-orange/10 text-grill-orange">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-car"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-cream">Parking</p>
              <p class="mt-0.5 text-sm text-cream/60">Street parking available along Jalan Metro Wangsa. Mall parking nearby.</p>
            </div>
          </div>
        </div>

        <div class="mt-8">
          <Button
            href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.address.full)}`}
            variant="primary"
          >
            Get Directions
          </Button>
        </div>
      </div>

      <!-- Reservation Form -->
      <div class="rounded-sm bg-wood-brown p-6 sm:p-10">
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-grill-orange">Reservations</p>
        <h2 class="mt-3 font-display text-2xl font-bold text-cream sm:text-3xl">Book a table</h2>
        <p class="mt-2 text-sm text-cream/60">Fill in your details and we'll WhatsApp you to confirm.</p>
        <div class="mt-6">
          <ReservationForm client:visible formspreeId={import.meta.env.PUBLIC_FORMSPREE_ID} />
        </div>
      </div>
    </div>
  </Container>
</section>

<!-- Contact Form Section -->
<section class="bg-wood-brown py-20 sm:py-28">
  <Container>
    <div class="mx-auto max-w-2xl">
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-grill-orange">Contact</p>
      <h2 class="mt-3 font-display text-3xl font-bold text-cream sm:text-4xl">Send us a message</h2>
      <p class="mt-2 text-base text-cream/60">General inquiries, feedback, or questions about our menu.</p>
      <div class="mt-8">
        <ContactForm client:visible formspreeId={import.meta.env.PUBLIC_FORMSPREE_ID} />
      </div>
    </div>
  </Container>
</section>
