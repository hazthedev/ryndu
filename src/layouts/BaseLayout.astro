---
import '../styles/global.css';
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/caveat/400.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
}

const {
  title,
  description,
  image = 'https://images.unsplash.com/photo-1544025162-d76694265947?q=80&w=1200&auto=format&fit=crop',
  canonical = Astro.url.pathname,
} = Astro.props;

const siteUrl = 'https://rynduhotgrill.com';
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`${siteUrl}${canonical}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}${canonical}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={`${siteUrl}${canonical}`} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD Restaurant Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Restaurant",
      "name": "Ryndu Hot & Grill",
      "image": ogImage,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "No 42, Jalan Metro Wangsa, Seksyen 2",
        "addressLocality": "Wangsa Maju",
        "addressRegion": "Kuala Lumpur",
        "postalCode": "53300",
        "addressCountry": "MY"
      },
      "telephone": "+60341415455",
      "priceRange": "$$",
      "servesCuisine": ["Western", "Steakhouse", "Halal", "Malaysian"],
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "11:00",
          "closes": "00:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Saturday", "Sunday"],
          "opens": "16:00",
          "closes": "00:00"
        }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.2",
        "reviewCount": "729"
      },
      "acceptsReservations": true,
      "url": siteUrl
    })} />
  </head>
  <body class="min-h-screen">
    <slot />
    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>
  </body>
</html>
