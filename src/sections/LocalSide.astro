---
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PlateCard from '../components/PlateCard.astro';
---

<section class="bg-wood-brown py-20 sm:py-28">
  <Container>
    <SectionHeading
      eyebrow="Local side"
      heading="Or skip western entirely."
      subheading="Beef Kuetiau, sandwiches, sets — Malaysian food cooked with the same care as the steaks."
    />

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <PlateCard
        image="https://images.unsplash.com/photo-1555126634-323283e090fa?q=80&w=600&auto=format&fit=crop"
        name="Beef Kuetiau"
        description="Silky flat rice noodles stir-fried with tender beef slices, egg, and bean sprouts in dark soy."
        price="RM12"
      />
      <PlateCard
        image="https://images.unsplash.com/photo-1603133872878-684f208fb84b?q=80&w=600&auto=format&fit=crop"
        name="Local Sets"
        description="Nasi Goreng Ayam, Mee Goreng, and more — Malaysian comfort food done right."
        price="RM12"
      />
      <PlateCard
        image="https://images.unsplash.com/photo-1528735602780-2552fd46c7af?q=80&w=600&auto=format&fit=crop"
        name="Sandwiches"
        description="Club sandwiches, chicken wraps, and more. Fresh, filling, and perfect for lunch."
        price="RM14"
      />
    </div>
  </Container>
</section>
