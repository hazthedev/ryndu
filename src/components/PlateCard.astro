---
const { image, name, description, price, houseFavorite = false } = Astro.props;
---

<div data-reveal class="h-full">
  <article class="group relative flex h-full flex-col overflow-hidden rounded-sm bg-ivory-cream shadow-md shadow-black/0 transition-[transform,box-shadow] duration-300 ease-smooth-out will-change-transform hover:-translate-y-1.5 hover:shadow-xl hover:shadow-grill-orange/25">
  <div class="aspect-[4/5] shrink-0 overflow-hidden">
    <img
      src={image}
      alt={name}
      class="h-full w-full object-cover transition-transform duration-700 ease-smooth-out will-change-transform group-hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="flex flex-1 flex-col p-5">
    <div class="flex flex-1 items-start justify-between gap-3">
      <div class="flex flex-col">
        <h3 class="font-display text-xl font-bold text-deep-charcoal">{name}</h3>
        <p class="mt-1 text-sm leading-relaxed text-deep-charcoal/70">{description}</p>
      </div>
      <span class="shrink-0 font-display text-lg font-bold text-grill-orange">{price}</span>
    </div>
    {houseFavorite && (
      <span class="mt-3 inline-block self-start rounded-full bg-brass-gold/10 px-3 py-1 text-xs font-medium uppercase tracking-wider text-brass-gold">
        House Favorite
      </span>
    )}
  </div>
</article>
</div>
