---
const { eyebrow, heading, subheading, align = 'center', light = false } = Astro.props;
---

<div data-reveal class:list={['max-w-3xl', align === 'center' ? 'mx-auto text-center' : 'text-left']}>
  {eyebrow && (
    <p class:list={['mb-3 text-xs font-medium uppercase tracking-[0.2em]', light ? 'text-grill-orange' : 'text-grill-orange']}>
      {eyebrow}
    </p>
  )}
  {heading && (
    <h2 class:list={['font-display text-3xl font-bold leading-tight sm:text-4xl lg:text-5xl', light ? 'text-deep-charcoal' : 'text-cream']}>
      {heading}
    </h2>
  )}
  {subheading && (
    <p class:list={['mt-4 text-base leading-relaxed sm:text-lg', light ? 'text-deep-charcoal/80' : 'text-cream/70']}>
      {subheading}
    </p>
  )}
</div>
