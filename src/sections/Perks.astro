---
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<section class="bg-ivory-cream py-20 sm:py-28">
  <Container>
    <SectionHeading
      eyebrow="The perks"
      heading="Bring you. Bring everyone."
      align="center"
      light={true}
    />

    <div class="mt-14 grid gap-8 sm:grid-cols-3">
      <!-- Birthday brownies -->
      <div class="group rounded-sm bg-deep-charcoal p-8 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-grill-orange/10">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-grill-orange/10 text-grill-orange transition-transform duration-300 group-hover:rotate-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-cake"><path d="M20 21v-8a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8"/><path d="M4 16s.5-1 2-1 2.5 2 4 2 2.5-2 4-2 2.5 2 4 2 2-1 2-1"/><path d="M2 21h20"/><path d="M7 8v3"/><path d="M12 8v3"/><path d="M17 8v3"/><path d="M7 4h.01"/><path d="M12 4h.01"/><path d="M17 4h.01"/></svg>
        </div>
        <h3 class="mt-6 font-display text-xl font-bold text-cream">Birthday Brownies</h3>
        <p class="mt-2 text-sm leading-relaxed text-cream/60">Free warm chocolate brownie on your birthday. Just let us know when you reserve.</p>
      </div>

      <!-- Happy hour -->
      <div class="group rounded-sm bg-deep-charcoal p-8 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-grill-orange/10">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-grill-orange/10 text-grill-orange transition-transform duration-300 group-hover:rotate-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-party-popper"><path d="M5.8 11.3 2 22l10.7-3.79"/><path d="M4 3h.01"/><path d="M22 8h.01"/><path d="M15 2h.01"/><path d="M22 20h.01"/><path d="m22 2-2.24.75a2.9 2.9 0 0 1-1.69.25 3.5 3.5 0 0 0-3.08 1.76l-.55.96A3.51 3.51 0 0 1 12.3 6.5a2.9 2.9 0 0 0-1.51.17l-1.13.38a2.53 2.53 0 0 1-1.58 0 2.45 2.45 0 0 0-1.52.13L3 8.58"/><path d="m8 16 2.52-1.3"/><path d="m14 19 2.52-1.36"/><path d="M22 13v4l-4.33 1.45a3.5 3.5 0 0 1-2.33 0L11 16.17a2.46 2.46 0 0 0-1.53-.11l-1.1.33a2.54 2.54 0 0 1-1.56 0 2.48 2.48 0 0 0-1.53.1L2 17.87V22"/></svg>
        </div>
        <h3 class="mt-6 font-display text-xl font-bold text-cream">Happy Hour</h3>
        <p class="mt-2 text-sm leading-relaxed text-cream/60">10% off your total bill during our happy hour window. Ask our staff for timing.</p>
      </div>

      <!-- Family-style -->
      <div class="group rounded-sm bg-deep-charcoal p-8 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-grill-orange/10">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-grill-orange/10 text-grill-orange transition-transform duration-300 group-hover:rotate-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-utensils"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
        </div>
        <h3 class="mt-6 font-display text-xl font-bold text-cream">Family-Style</h3>
        <p class="mt-2 text-sm leading-relaxed text-cream/60">Built for groups. Large portions, sharing plates, and a vibe that fits birthdays and reunions.</p>
      </div>
    </div>
  </Container>
</section>
