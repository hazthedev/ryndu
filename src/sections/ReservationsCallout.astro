---
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
---

<section class="bg-wood-brown py-20 sm:py-28">
  <Container>
    <div class="grid items-center gap-10 overflow-hidden rounded-sm bg-deep-charcoal lg:grid-cols-2">
      <div class="aspect-[4/3] lg:aspect-auto lg:h-full">
        <img
          src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?q=80&w=1000&auto=format&fit=crop"
          alt="Ryndu restaurant interior"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
      <div class="p-8 sm:p-12">
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-grill-orange">Reservations</p>
        <h2 class="mt-4 font-display text-3xl font-bold text-cream sm:text-4xl">Reserve ahead.</h2>
        <p class="mt-4 text-base leading-relaxed text-cream/70">
          Friday and Saturday fill up fast. WhatsApp us — we usually confirm in under 30 minutes.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href="/visit" variant="primary">Reserve a Table</Button>
          <Button href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER || '60123456789'}?text=Hi%20Ryndu,%20I%20would%20like%20to%20make%20a%20reservation.`} variant="outline">
            WhatsApp Us
          </Button>
        </div>
      </div>
    </div>
  </Container>
</section>
