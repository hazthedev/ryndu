---
import Container from '../components/Container.astro';
---

<section class="bg-ivory-cream py-16 sm:py-24">
  <Container>
    <div class="text-center">
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-grill-orange">Follow us</p>
      <h2 class="mt-3 font-display text-3xl font-bold text-deep-charcoal sm:text-4xl">Stay connected</h2>
      <p class="mx-auto mt-4 max-w-xl text-base text-deep-charcoal/70">
        See what's cooking, catch our latest promotions, and tag us when you visit.
      </p>
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-6">
      <a
        href="https://www.instagram.com/rynduhotgrill"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 rounded-sm bg-deep-charcoal px-8 py-4 text-cream transition-all duration-300 hover:-translate-y-1 hover:bg-grill-orange"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        <span class="text-sm font-medium">@rynduhotgrill</span>
      </a>

      <a
        href="https://www.facebook.com/rynduhotgrill"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 rounded-sm bg-deep-charcoal px-8 py-4 text-cream transition-all duration-300 hover:-translate-y-1 hover:bg-grill-orange"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        <span class="text-sm font-medium">Ryndu Hot & Grill</span>
      </a>

      <a
        href={import.meta.env.PUBLIC_EASYEAT_URL || '#'}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 rounded-sm bg-deep-charcoal px-8 py-4 text-cream transition-all duration-300 hover:-translate-y-1 hover:bg-grill-orange"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="text-sm font-medium">Order on EasyEat</span>
      </a>
    </div>
  </Container>
</section>
