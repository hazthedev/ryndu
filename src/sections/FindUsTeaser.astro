---
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import site from '../data/site.json';
---

<section class="bg-wood-brown py-20 sm:py-28">
  <Container>
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <!-- Map preview -->
      <div class="aspect-video overflow-hidden rounded-sm">
        <iframe
          src={site.googleMapsEmbed}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ryndu Hot & Grill location map"
          class="h-full w-full"
        ></iframe>
      </div>

      <!-- Details -->
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-grill-orange">Find us</p>
        <h2 class="mt-3 font-display text-3xl font-bold text-cream sm:text-4xl">
          Wangsa Maju, Kuala Lumpur
        </h2>
        <p class="mt-4 text-base leading-relaxed text-cream/70">
          {site.address.full}
        </p>

        <div class="mt-8 space-y-4">
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-grill-orange/10 text-grill-orange">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-cream">{site.hours.weekday.days}: {site.hours.weekday.label}</p>
              <p class="text-sm text-cream/60">{site.hours.weekend.days}: {site.hours.weekend.label}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-grill-orange/10 text-grill-orange">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-cream">{site.phone}</p>
              <p class="text-sm text-cream/60">Call or WhatsApp for reservations</p>
            </div>
          </div>
        </div>

        <div class="mt-10 flex flex-col gap-3 sm:flex-row">
          <Button href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.address.full)}`} variant="primary">
            Get Directions
          </Button>
          <Button href="/visit" variant="outline">
            Reserve a Table
          </Button>
        </div>
      </div>
    </div>
  </Container>
</section>
